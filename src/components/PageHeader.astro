---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---

<section class="hero-surface relative overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 md:py-16">
    {
      eyebrow && (
        <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-semibold tracking-[0.15em] text-accent-300 uppercase">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-400" />
          {eyebrow}
        </p>
      )
    }
    <h1 class="text-4xl text-white sm:text-5xl md:text-6xl">{title}</h1>
    {
      description && (
        <p class="mt-4 max-w-2xl text-lg text-slate-300">{description}</p>
      )
    }
    <slot />
  </div>
</section>
