---
import profileData from "../data/profile.yaml";
const year = new Date().getFullYear();
---

<footer
  class="border-t border-slate-200 py-8 dark:border-slate-800"
>
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-4 text-sm text-slate-500 sm:flex-row sm:px-6 dark:text-slate-400"
  >
    <p>© {year} {profileData.name}</p>
    <div class="flex gap-4">
      {
        profileData.social.map((s: { label: string; url: string }) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-brand-600 dark:hover:text-brand-500"
          >
            {s.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
