---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const videos = await getCollection("videos");
---

<BaseLayout
  title="Videos & Webinars"
  description="Webinars and technical video content on Apache Pulsar and event streaming."
>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      Videos &amp; Webinars
    </h1>
    <p class="mt-3 max-w-prose text-slate-600 dark:text-slate-300">
      Deep dives, tutorials, and webinars on Apache Pulsar and event streaming.
    </p>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        videos.map((video) => (
          <li>
            <a
              href={video.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex h-full items-start gap-3 rounded-xl border border-slate-200 p-4 hover:border-brand-500 hover:shadow-md dark:border-slate-800"
            >
              <span class="mt-0.5 text-brand-600 dark:text-brand-500">▶</span>
              <span class="font-medium group-hover:text-brand-600 dark:group-hover:text-brand-500">
                {video.data.title}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
