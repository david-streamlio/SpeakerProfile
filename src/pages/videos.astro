---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const videos = await getCollection("videos");
---

<BaseLayout
  title="Videos & Webinars"
  description="Webinars and technical video content on Apache Pulsar and event streaming."
>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <h1 class="text-4xl tracking-tight sm:text-5xl">
      Videos &amp; Webinars
    </h1>
    <p class="mt-3 max-w-prose text-slate-600 dark:text-slate-300">
      Deep dives, tutorials, and webinars on Apache Pulsar and event streaming.
    </p>

    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        videos.map((video) => {
          const card =
            "group flex h-full items-start gap-3 rounded-xl border border-slate-200 p-4 dark:border-slate-800";
          const Body = (
            <span>
              <span
                class:list={[
                  "font-medium",
                  video.data.url &&
                    "group-hover:text-brand-600 dark:group-hover:text-brand-500",
                ]}
              >
                {video.data.title}
              </span>
              {video.data.coHost && (
                <span class="mt-0.5 block text-xs text-slate-500 dark:text-slate-400">
                  with {video.data.coHost}
                </span>
              )}
              {video.data.description && (
                <span class="mt-1 block text-sm text-slate-600 dark:text-slate-300">
                  {video.data.description}
                </span>
              )}
              {!video.data.url && (
                <span class="mt-1 block text-xs text-slate-400 dark:text-slate-500">
                  Recording coming soon
                </span>
              )}
            </span>
          );
          return (
            <li>
              {video.data.url ? (
                <a
                  href={video.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`${card} hover:border-brand-500 hover:shadow-md`}
                >
                  <span class="mt-0.5 text-brand-600 dark:text-brand-500">▶</span>
                  {Body}
                </a>
              ) : (
                <div class={card}>
                  <span class="mt-0.5 text-slate-400 dark:text-slate-500">▶</span>
                  {Body}
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
