---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import profileData from "../data/profile.yaml";
import conferences from "../data/conferences.yaml";
import { hero } from "../data/images";
import { getCollection } from "astro:content";

const talks = await getCollection("talks");
const eventCount = new Set(talks.map((t) => t.data.event)).size;

const recentBlog = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const sessionize = profileData.social.find(
  (s: { label: string }) => s.label === "Sessionize",
)?.url;

// Extract the YouTube id from the featured video watch URL.
const fv = profileData.featuredVideo;
const ytId = fv?.url?.match(/[?&]v=([^&]+)/)?.[1];

const stats = [
  { value: `${talks.length}`, label: "Talks delivered" },
  { value: `${eventCount}+`, label: "Conferences" },
  { value: `${profileData.books.length}`, label: "Books authored" },
  { value: "7 yrs", label: "Pulsar committer" },
];
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section class="hero-surface relative overflow-hidden">
    <div
      class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 md:grid-cols-[1.15fr_0.85fr] md:py-24"
    >
      <div>
        <p
          class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-semibold tracking-[0.15em] text-accent-300 uppercase"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>
          {profileData.title} · {profileData.company.name}
        </p>
        <h1 class="text-5xl leading-[1.02] sm:text-6xl md:text-7xl">
          <span class="text-gradient">{profileData.positioning.headline}</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-slate-300">
          {profileData.positioning.subhead}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={sessionize}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-xl bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-accent-500/25 transition hover:bg-accent-400"
          >
            Invite me to speak
          </a>
          <a
            href="#featured"
            class="rounded-xl border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            ▶ Watch a talk
          </a>
        </div>
        <dl class="mt-12 grid max-w-lg grid-cols-2 gap-6 sm:grid-cols-4">
          {
            stats.map((s) => (
              <div>
                <dt class="font-display text-2xl font-bold text-white sm:text-3xl">
                  {s.value}
                </dt>
                <dd class="mt-1 text-xs text-slate-400">{s.label}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="relative">
        <div
          class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-accent-500/30 to-indigo-500/20 blur-2xl"
        >
        </div>
        <Image
          src={hero}
          alt={`${profileData.name} speaking`}
          class="relative aspect-[4/5] w-full rounded-3xl object-cover shadow-2xl ring-1 ring-white/10"
          widths={[480, 800, 1000]}
          sizes="(min-width: 768px) 38vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>

    <!-- As seen at -->
    <div class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
        <p
          class="text-center text-xs font-semibold tracking-[0.2em] text-slate-400 uppercase"
        >
          As seen at
        </p>
        <ul
          class="mt-5 flex flex-wrap items-center justify-center gap-3"
        >
          {
            conferences.map(
              (c: { name: string; logo?: string }) =>
                c.logo ? (
                  <li class="flex h-12 items-center justify-center rounded-lg bg-white px-3 shadow-sm grayscale transition hover:grayscale-0">
                    <img
                      src={c.logo}
                      alt={c.name}
                      class="max-h-8 w-auto max-w-[120px] object-contain"
                      loading="lazy"
                    />
                  </li>
                ) : (
                  <li class="font-display px-2 text-sm font-semibold text-slate-400 transition hover:text-accent-300">
                    {c.name}
                  </li>
                ),
            )
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ SIGNATURE TOPICS ============ -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20">
    <div class="reveal max-w-2xl">
      <p
        class="text-sm font-semibold tracking-wide text-accent-600 uppercase dark:text-accent-400"
      >
        What I speak about
      </p>
      <h2 class="mt-2 text-3xl sm:text-4xl">Signature topics</h2>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        profileData.topics.map(
          (topic: { title: string; description: string }, i: number) => (
            <div class="reveal rounded-2xl border border-slate-200 p-6 transition hover:border-accent-400 hover:shadow-md dark:border-slate-800">
              <span class="font-display text-sm font-bold text-accent-500">
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="mt-2 text-xl">{topic.title}</h3>
              <p class="mt-2 text-slate-600 dark:text-slate-300">
                {topic.description}
              </p>
            </div>
          ),
        )
      }
    </div>
  </section>

  <!-- ============ FEATURED TALK ============ -->
  {
    ytId && (
      <section
        id="featured"
        class="scroll-mt-20 border-y border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/40"
      >
        <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 md:py-20">
          <div class="reveal mb-8 max-w-2xl">
            <p class="text-sm font-semibold tracking-wide text-accent-600 uppercase dark:text-accent-400">
              On stage
            </p>
            <h2 class="mt-2 text-3xl sm:text-4xl">Featured talk</h2>
            <p class="mt-2 text-slate-600 dark:text-slate-300">
              {fv.title}
            </p>
          </div>
          <div class="reveal overflow-hidden rounded-2xl shadow-xl ring-1 ring-slate-200 dark:ring-slate-800">
            <div class="aspect-video">
              <iframe
                class="h-full w-full"
                src={`https://www.youtube-nocookie.com/embed/${ytId}`}
                title={fv.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          </div>
          <div class="mt-6 text-center">
            <a
              href="/talks/"
              class="text-sm font-semibold text-accent-600 hover:text-accent-700 dark:text-accent-400"
            >
              Browse all {talks.length} talks →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- ============ ABOUT ============ -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h2 class="reveal text-3xl sm:text-4xl">About</h2>
    <div class="prose-content reveal mt-5">
      {profileData.bio.map((p: string) => <p>{p}</p>)}
    </div>
  </section>

  <!-- ============ BOOKS ============ -->
  <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
    <h2 class="reveal text-3xl sm:text-4xl">Books</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        profileData.books.map(
          (book: {
            title: string;
            publisher: string;
            url: string;
            role: string;
            description: string;
          }) => (
            <a
              href={book.url}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal group rounded-2xl border border-slate-200 p-6 transition hover:border-accent-400 hover:shadow-md dark:border-slate-800"
            >
              <p class="text-xs font-semibold tracking-wide text-accent-600 uppercase dark:text-accent-400">
                {book.role} · {book.publisher}
              </p>
              <h3 class="mt-1 text-xl group-hover:text-accent-600 dark:group-hover:text-accent-400">
                {book.title}
              </h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                {book.description}
              </p>
            </a>
          ),
        )
      }
    </div>
  </section>

  <!-- ============ BOOKING CTA ============ -->
  <section class="px-4 pb-16 sm:px-6">
    <div
      class="hero-surface reveal mx-auto max-w-6xl overflow-hidden rounded-3xl px-6 py-12 text-center sm:py-16"
    >
      <h2 class="text-3xl text-white sm:text-4xl">Let's work together</h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-300">
        Available for {profileData.availableFor.join(", ").toLowerCase()}.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a
          href={sessionize}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-xl bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-accent-500/25 transition hover:bg-accent-400"
        >
          Invite me to speak
        </a>
        <a
          href={profileData.social.find(
            (s: { label: string }) => s.label === "LinkedIn",
          )?.url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-xl border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- ============ RECENT WRITING ============ -->
  {
    recentBlog.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
        <div class="reveal flex items-center justify-between">
          <h2 class="text-3xl sm:text-4xl">From the blog</h2>
          <a
            href="/blog/"
            class="text-sm font-semibold text-accent-600 hover:text-accent-700 dark:text-accent-400"
          >
            All posts →
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {recentBlog.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="reveal group rounded-2xl border border-slate-200 p-6 transition hover:border-accent-400 hover:shadow-md dark:border-slate-800"
            >
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-xs text-slate-500 dark:text-slate-400"
              >
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <h3 class="mt-1 text-xl group-hover:text-accent-600 dark:group-hover:text-accent-400">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  // Reveal-on-scroll
  const els = document.querySelectorAll(".reveal");
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px" },
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add("is-visible"));
  }
</script>
