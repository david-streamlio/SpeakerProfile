---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => import.meta.env.PROD ? !p.data.draft : true)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Writing on Apache Pulsar, event streaming, and real-time data systems."
>
  <PageHeader
    eyebrow="Writing"
    title="Blog"
    description="Writing on Apache Pulsar, event streaming, and real-time data systems."
  >
    <a
      href="/rss.xml"
      class="mt-6 inline-flex items-center gap-2 rounded-lg border border-white/20 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10"
      >RSS feed →</a
    >
  </PageHeader>

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    {
      posts.length === 0 ? (
        <p class="text-slate-500 dark:text-slate-400">
          No posts yet — check back soon.
        </p>
      ) : (
        <ul class="space-y-8">
          {posts.map((post) => (
            <li>
              <article>
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-slate-500 dark:text-slate-400"
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <h2 class="mt-1 text-xl font-bold">
                  <a
                    href={`/blog/${post.id}/`}
                    class="hover:text-accent-600 dark:hover:text-accent-400"
                  >
                    {post.data.title}
                    {post.data.draft && (
                      <span class="ml-2 rounded bg-amber-100 px-1.5 py-0.5 text-xs font-semibold text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">
                        Draft
                      </span>
                    )}
                  </a>
                </h2>
                <p class="mt-2 text-slate-600 dark:text-slate-300">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
