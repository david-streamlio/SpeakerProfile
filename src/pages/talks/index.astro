---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";

const talks = (await getCollection("talks")).sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  return a.data.event.localeCompare(b.data.event);
});

const years = [...new Set(talks.map((t) => t.data.year))].sort((a, b) => b - a);
---

<BaseLayout
  title="Talks"
  description="Conference talks delivered around the world on real-time data, messaging, and streaming."
>
  <PageHeader
    eyebrow="Speaking"
    title="Talks"
    description={`${talks.length} conference appearances around the globe. Filter by year, or follow the links to watch a recording.`}
  />

  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <!-- Year filter -->
    <div class="flex flex-wrap gap-2" id="year-filters">
      <button
        type="button"
        data-year="all"
        class="year-btn rounded-full bg-accent-500 px-3.5 py-1.5 text-sm font-medium text-white"
        >All</button
      >
      {
        years.map((y) => (
          <button
            type="button"
            data-year={y}
            class="year-btn rounded-full bg-slate-100 px-3.5 py-1.5 text-sm font-medium hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700"
          >
            {y}
          </button>
        ))
      }
    </div>

    <ul class="mt-8 divide-y divide-slate-200 dark:divide-slate-800">
      {
        talks.map((talk) => (
          <li
            class="talk-row flex flex-wrap items-baseline justify-between gap-2 py-4"
            data-year={talk.data.year}
          >
            <div class="min-w-0">
              <p class="font-semibold">
                {talk.data.title ?? talk.data.event}
              </p>
              {talk.data.title && (
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  {talk.data.event}
                </p>
              )}
            </div>
            <div class="flex shrink-0 items-center gap-3">
              <span class="text-sm tabular-nums text-slate-500 dark:text-slate-400">
                {talk.data.year}
              </span>
              {talk.data.videoUrl && (
                <a
                  href={talk.data.videoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-accent-600 hover:bg-slate-200 dark:bg-slate-800 dark:text-accent-400 dark:hover:bg-slate-700"
                >
                  ▶ Watch
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<script is:inline>
  const filters = document.getElementById("year-filters");
  const rows = Array.from(document.querySelectorAll(".talk-row"));
  filters?.addEventListener("click", (e) => {
    const btn = e.target.closest(".year-btn");
    if (!btn) return;
    const year = btn.dataset.year;
    document.querySelectorAll(".year-btn").forEach((b) => {
      const active = b === btn;
      b.classList.toggle("bg-accent-500", active);
      b.classList.toggle("text-white", active);
      b.classList.toggle("bg-slate-100", !active);
      b.classList.toggle("dark:bg-slate-800", !active);
    });
    rows.forEach((row) => {
      row.style.display =
        year === "all" || row.dataset.year === year ? "" : "none";
    });
  });
</script>
